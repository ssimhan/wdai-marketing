# Luma API key — get from lu.ma/home/settings/integrations (requires Luma Plus)
LUMA_API_KEY=

# Set to "true" to run sync with mock data (no API key needed)
LUMA_MOCK=false

# Slack incoming webhook URL for calendar notifications
# Leave blank to skip notifications
SLACK_WEBHOOK_URL=

# Slack Bot OAuth token (xoxb-...) — for copy review DMs (Phase 5)
SLACK_BOT_TOKEN=

# Slack signing secret — for verifying button click payloads at /api/slack/interactions
SLACK_SIGNING_SECRET=

# GitHub fine-grained token with contents:write on this repo — used by the interactions endpoint
# to update vault/status/<luma_id>.yaml when a plan is approved via Slack
GITHUB_TOKEN=
GITHUB_OWNER=womendefiningai
GITHUB_REPO=wdai-marketing

# Anthropic API key — for AI copy generation (Phase 5)
ANTHROPIC_API_KEY=
